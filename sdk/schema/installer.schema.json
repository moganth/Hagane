{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://installer-engine/schema/installer.schema.json",
  "title": "Installer Engine Manifest",
  "description": "YAML manifest schema for installer-engine. Provides IDE autocomplete and validation.",
  "type": "object",
  "required": ["app", "pages", "steps"],
  "additionalProperties": false,
  "properties": {
    "app": {
      "type": "object",
      "required": ["name", "version", "publisher"],
      "additionalProperties": false,
      "properties": {
        "name":                { "type": "string", "description": "Application name shown throughout the installer." },
        "version":             { "type": "string", "description": "Version string, e.g. '2.1.0'." },
        "publisher":           { "type": "string", "description": "Publisher / company name." },
        "description":         { "type": "string" },
        "website":             { "type": "string", "format": "uri" },
        "support_url":         { "type": "string", "format": "uri" },
        "logo":                { "type": "string", "description": "Relative path to logo PNG (48×48 recommended)." },
        "banner":              { "type": "string", "description": "Relative path to banner PNG." },
        "icon":                { "type": "string", "description": "Relative path to .ico file for the installer exe." },
        "default_install_dir": { "type": "string", "description": "Default install path. Supports {{PROGRAMFILES64}}/{{APPDATA}}/{{LOCALAPPDATA}} and legacy $PROGRAMFILES64/$APPDATA/$LOCALAPPDATA." },
        "registry_key":        { "type": "string", "description": "Registry key suffix under SOFTWARE\\\\." },
        "require_admin":       { "type": "boolean", "default": true }
      }
    },
    "variables": {
      "type": "object",
      "description": "User-declared reusable variables. Reference with {{KEY}} (preferred) or legacy $KEY. Keys should use A-Z, 0-9, and '_' (optionally prefixed with '$').",
      "additionalProperties": {
        "type": "string"
      }
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accent_color":     { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$", "description": "Hex color, e.g. '#0078D4'." },
        "background_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "text_color":       { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "font_family":      { "type": "string" },
        "font_size":        { "type": "integer", "minimum": 8, "maximum": 24 },
        "border_radius":    { "type": "integer", "minimum": 0, "maximum": 24 },
        "banner_position":  { "type": "string", "enum": ["top", "left", "none"] },
        "window_width":     { "type": "integer", "minimum": 600, "maximum": 1200 },
        "window_height":    { "type": "integer", "minimum": 400, "maximum": 900 }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["welcome", "license", "requirements", "install_dir", "components", "user_info", "summary", "install", "finish", "error"],
            "description": "Page type — determines which UI template is rendered."
          },
          "title":       { "type": "string" },
          "subtitle":    { "type": "string" },
          "custom_html": { "type": "string", "description": "Relative path to a custom .html page for full override." },
          "data":        { "type": "object", "description": "Extra data passed to the page template." }
        }
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type":        { "type": "string", "enum": ["os", "ram", "disk", "dotnet", "vc_redist", "custom"] },
          "platform":    { "type": "string", "enum": ["windows"] },
          "min_build":   { "type": "integer", "description": "Windows build number. 10240=Win10, 22000=Win11." },
          "min_mb":      { "type": "integer", "description": "Minimum megabytes (RAM or disk)." },
          "path":        { "type": "string", "description": "Drive/path to check for disk space." },
          "min_version": { "type": "string", "description": ".NET Framework version, e.g. '4.8'." },
          "year":        { "type": "string", "description": "VC++ redistributable year, e.g. '2022'." },
          "arch":        { "type": "string", "enum": ["x86", "x64", "arm64"] },
          "label":       { "type": "string", "description": "Human-readable label shown on the requirements page." },
          "id":          { "type": "string", "description": "Unique ID for custom requirements." },
          "check_script":{ "type": "string", "description": "PowerShell snippet for custom checks (last resort)." }
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string", "description": "Unique component identifier used in steps." },
          "name":        { "type": "string" },
          "description": { "type": "string" },
          "size_mb":     { "type": "integer" },
          "required":    { "type": "boolean", "default": false },
          "selected":    { "type": "boolean", "default": true },
          "depends_on":  { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["action"],
        "properties": {
          "action": {
            "type": "string",
            "enum": ["extract", "copy_file", "delete_file", "create_dir", "log_ui", "log_file", "log_both", "registry", "register_uninstall", "register_app", "shortcut", "env_var", "service", "run_program", "run_powershell", "write_uninstaller"]
          },
          "archive":      { "type": "string", "description": "Archive name registered during build (extract)." },
          "destination":  { "type": "string" },
          "source":       { "type": "string" },
          "path":         { "type": "string" },
          "overwrite":    { "type": "boolean", "default": false },
          "component":    { "type": "string", "description": "Only run this step if this component ID is selected." },
          "operation":    { "type": "string", "enum": ["write", "delete", "create_key", "delete_key", "install", "start", "stop"] },
          "hive":         { "type": "string", "enum": ["HKLM", "HKCU", "HKCR", "HKU", "HKCC"] },
          "key":          { "type": "string" },
          "value_name":   { "type": "string" },
          "value_type":   { "type": "string", "enum": ["SZ", "EXPAND_SZ", "DWORD", "QWORD", "MULTI_SZ", "BINARY"] },
          "value_data":   {},
          "display_name": { "type": "string", "description": "Used by register_uninstall (supports alias 'name')." },
          "display_version": { "type": "string", "description": "Used by register_uninstall (supports alias 'version')." },
          "publisher":   { "type": "string", "description": "Used by register_uninstall." },
          "install_location": { "type": "string", "description": "Used by register_uninstall (supports alias 'inst_loc')." },
          "uninstall_string": { "type": "string", "description": "Used by register_uninstall (supports alias 'uninstall')." },
          "estimated_size_kb": { "type": "integer", "minimum": 0, "description": "Optional EstimatedSize DWORD for register_uninstall." },
          "no_modify":   { "type": "boolean", "default": true, "description": "Used by register_uninstall; writes NoModify DWORD." },
          "no_repair":   { "type": "boolean", "default": true, "description": "Used by register_uninstall; writes NoRepair DWORD." },
          "inst_loc": { "type": "string", "description": "Used by register_app (alias for install location; writes InstallDir)." },
          "version": { "type": "string", "description": "Used by register_app (writes Version)." },
          "target":       { "type": "string" },
          "location":     { "type": "string", "enum": ["desktop", "start_menu", "startup"] },
          "name":         { "type": "string" },
          "description":  { "type": "string" },
          "icon":         { "type": "string" },
          "arguments":    { "type": "string" },
          "working_dir":  { "type": "string" },
          "value":        { "type": "string" },
          "scope":        { "type": "string", "enum": ["user", "system"] },
          "display_name": { "type": "string" },
          "executable":   { "type": "string" },
          "start_type":   { "type": "string", "enum": ["auto", "manual", "disabled"] },
          "wait":         { "type": "boolean", "default": true }
        }
      }
    },
    "uninstall": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "display_name": { "type": "string" },
        "publisher":    { "type": "string" },
        "extra_steps":  { "type": "array" }
      }
    },
    "silent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "install_dir": { "type": "string" },
        "components":  { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}