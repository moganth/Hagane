{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://installer-engine/schema/installer.schema.json",
  "title": "Installer Engine Manifest",
  "description": "YAML manifest schema for installer-engine using install DSL.",
  "type": "object",
  "required": ["app", "pages", "install"],
  "additionalProperties": false,
  "properties": {
    "app": {
      "type": "object",
      "required": ["name", "version", "publisher"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "publisher": { "type": "string" },
        "description": { "type": "string" },
        "website": { "type": "string", "format": "uri" },
        "support_url": { "type": "string", "format": "uri" },
        "logo": { "type": "string" },
        "banner": { "type": "string" },
        "icon": { "type": "string" },
        "default_install_dir": { "type": "string" },
        "registry_key": { "type": "string" },
        "require_admin": { "type": "boolean", "default": true }
      }
    },
    "variables": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accent_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "accent_dark_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "accent_light_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "background_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "surface_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "text_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "text_muted_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "border_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "success_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "success_bg_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "error_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "error_bg_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "progress_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "progress_light_color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "font_family": { "type": "string" },
        "border_radius": { "type": "integer", "minimum": 0, "maximum": 24 },
        "banner_position": { "type": "string", "enum": ["top", "left", "none"] },
        "window_width": { "type": "integer", "minimum": 600, "maximum": 1200 },
        "window_height": { "type": "integer", "minimum": 400, "maximum": 900 }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["welcome", "license", "requirements", "install_dir", "components", "user_info", "summary", "install", "finish", "error"]
          },
          "title": { "type": "string" },
          "subtitle": { "type": "string" },
          "custom_html": { "type": "string" },
          "data": { "type": "object" }
        }
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["os", "ram", "disk", "dotnet", "vc_redist", "custom"] },
          "platform": { "type": "string", "enum": ["windows"] },
          "min_build": { "type": "integer" },
          "min_mb": { "type": "integer" },
          "path": { "type": "string" },
          "min_version": { "type": "string" },
          "year": { "type": "string" },
          "arch": { "type": "string", "enum": ["x86", "x64", "arm64"] },
          "label": { "type": "string" },
          "id": { "type": "string" },
          "check_script": { "type": "string" }
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "size_mb": { "type": "integer" },
          "required": { "type": "boolean", "default": false },
          "selected": { "type": "boolean", "default": true },
          "depends_on": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["auto", "manual_only"], "default": "auto" },
        "path": { "type": "string" },
        "file_name": { "type": "string" },
        "timestamp": { "type": "boolean", "default": true },
        "include_raw_os_error": { "type": "boolean", "default": false },
        "slow_step_warn_sec": { "type": "integer", "minimum": 1 }
      }
    },
    "install": {
      "type": "object",
      "required": ["setup", "components", "system", "finalize"],
      "additionalProperties": false,
      "properties": {
        "setup": {
          "type": "object",
          "required": ["create_dirs"],
          "additionalProperties": false,
          "properties": {
            "create_dirs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
          }
        },
        "components": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "required": ["archive", "target"],
            "additionalProperties": false,
            "properties": {
              "archive": { "type": "string" },
              "target": { "type": "string" }
            }
          }
        },
        "system": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "register_app": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "key": { "type": "string" },
                "hive": { "type": "string", "enum": ["HKLM", "HKCU", "HKCR", "HKU", "HKCC"] },
                "name": { "type": "string" },
                "version": { "type": "string" },
                "publisher": { "type": "string" },
                "install_location": { "type": "string" }
              }
            },
            "register_uninstall": {
              "type": "object",
              "required": ["key"],
              "additionalProperties": false,
              "properties": {
                "key": { "type": "string" },
                "hive": { "type": "string", "enum": ["HKLM", "HKCU", "HKCR", "HKU", "HKCC"] },
                "name": { "type": "string" },
                "version": { "type": "string" },
                "publisher": { "type": "string" },
                "install_location": { "type": "string" },
                "uninstall": { "type": "string" },
                "estimated_size_kb": { "type": "integer", "minimum": 0 },
                "no_modify": { "type": "boolean" },
                "no_repair": { "type": "boolean" }
              }
            },
            "shortcuts": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "target", "location"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string" },
                  "target": { "type": "string" },
                  "location": { "type": "string", "enum": ["desktop", "start_menu", "startup"] },
                  "description": { "type": "string" },
                  "icon": { "type": "string" },
                  "arguments": { "type": "string" },
                  "working_dir": { "type": "string" },
                  "component": { "type": "string" }
                }
              }
            },
            "path": {
              "type": "object",
              "required": ["add"],
              "additionalProperties": false,
              "properties": {
                "add": { "type": "string" },
                "scope": { "type": "string", "enum": ["user", "system"] },
                "component": { "type": "string" }
              }
            }
          }
        },
        "hooks": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "post_install": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["run"],
                "additionalProperties": false,
                "properties": {
                  "run": {
                    "type": "object",
                    "required": ["command", "shell"],
                    "additionalProperties": false,
                    "properties": {
                      "command": { "type": "string" },
                      "shell": { "type": "string", "enum": ["powershell", "program"] },
                      "wait": { "type": "boolean", "default": true },
                      "fail_on_nonzero": { "type": "boolean", "default": true },
                      "timeout_sec": { "type": "integer", "minimum": 1 }
                    }
                  }
                }
              }
            }
          }
        },
        "finalize": {
          "type": "object",
          "required": ["write_uninstaller"],
          "additionalProperties": false,
          "properties": {
            "write_uninstaller": { "type": "string" }
          }
        }
      }
    },
    "uninstall": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "display_name": { "type": "string" },
        "publisher": { "type": "string" },
        "extra_steps": { "type": "array" }
      }
    },
    "silent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "install_dir": { "type": "string" },
        "components": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
